{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "baseUrl": ".",
    "lib": ["ESNext", "DOM"],
    "paths": {
      "config/*": ["tests/config/*"],
      "pages/*": ["tests/pages/*"],
      "labels/*": ["tests/labels/*"],
      "fixtures/*": ["tests/fixtures/*"],
      "mocks/*": ["tests/mocks/*"],
      "support/*": ["tests/support/*"]
    },
    "types": ["node", "@playwright/test"],
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true
  }
}
